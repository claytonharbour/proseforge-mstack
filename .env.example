# Google AI API Key (for Gemini TTS)
# Get yours at: https://aistudio.google.com/apikey
GOOGLE_AI_API_KEY=your-google-ai-api-key-here

# TTS Voice Configuration
# Options: Kore (professional), Aoede (warm), Puck (neutral), Charon (authoritative)
# Full list: https://console.cloud.google.com/speech/text-to-speech
TTS_VOICE=Kore

# TTS Speed (0.25 to 4.0, default 1.0)
TTS_SPEED=1.0

# Claude API (for social media --ai flag)
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# YouTube Configuration
YOUTUBE_CHANNEL_ID=your-youtube-channel-id
YOUTUBE_PLAYLIST_ID=your-youtube-playlist-id

# Social Media API Keys (future - for automated posting)
# These require app approval from each platform
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=
FACEBOOK_ACCESS_TOKEN=
LINKEDIN_ACCESS_TOKEN=
